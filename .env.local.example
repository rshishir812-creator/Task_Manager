# Supabase — get from: https://supabase.com/dashboard/project/<your-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Your local dev URL (update to your Vercel URL for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: NEXT_PUBLIC_GOOGLE_CLIENT_ID is NOT needed here.
# Supabase holds the Google OAuth client ID/secret on its side.
